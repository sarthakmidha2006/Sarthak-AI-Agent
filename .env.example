# =============================================================================
# Example environment — copy to `.env` and fill in. Do NOT commit real secrets.
# Stack: OpenRouter (chat) · Groq Whisper (STT) · local sentence-transformers
#        (embeddings) · local Piper (TTS).
# =============================================================================

# --- Chat provider: OpenRouter (OpenAI-compatible) ---
# API key: https://openrouter.ai/keys
CHAT_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your_openrouter_api_key
# Switch chat models by editing this line only (provider prefix required).
OPENAI_CHAT_MODEL=openai/gpt-4.1-mini
# Optional OpenRouter ranking headers (sent only when non-empty).
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=

# --- Speech-to-text: Groq Whisper (OpenRouter has no transcription endpoint) ---
# Free API key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_STT_MODEL=whisper-large-v3
# Optional legacy / STT-fallback credential.
OPENAI_API_KEY=

# --- Embeddings: local sentence-transformers (downloaded once, then offline) ---
OPENAI_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Reranker ---
# "none"   -> skip reranking; use fused RRF order directly (zero Groq tokens).
# "llm"    -> Groq JSON-mode reranker (highest quality, ~4.3k tokens/query).
# "cohere" -> Cohere rerank endpoint (needs COHERE_API_KEY).
RERANKER_PROVIDER=none
RERANKER_MODEL=llama-3.1-8b-instant

# --- Text-to-speech: local Piper (place the .onnx + .onnx.json under data/piper) ---
PIPER_MODEL_PATH=./data/piper/en_US-lessac-medium.onnx
PIPER_LENGTH_SCALE=1.0
TTS_MP3_BITRATE=64

# --- GitHub (optional; raises ingestion rate limits) ---
GITHUB_USERNAME=your-github-username
GITHUB_TOKEN=

# --- Persona ---
PERSONA_NAME="Your Name"
PERSONA_TITLE="AI Engineer Intern Candidate"
PERSONA_EMAIL=you@example.com

# --- Timezone ---
TIMEZONE=Asia/Kolkata

# --- Database ---
DATABASE_URL=sqlite:///./data/persona.db

# --- RAG (conservative free-tier retrieval; RERANK_CANDIDATES=0 is safe) ---
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=persona_corpus
RERANK_CANDIDATES=0
TOP_K_VECTOR=8
TOP_K_BM25=8
FINAL_CONTEXT_CHUNKS=4

# --- Security ---
INJECTION_GUARD_ENABLED=true
GROUNDING_CHECK_ENABLED=true
# Grounding backend: "rule_based" -> validate citations + lexical support with
# zero LLM calls (free-tier optimization); "llm" -> JSON-mode grounding judge.
GROUNDING_CHECK_PROVIDER=rule_based

# --- Vapi telephony bridge (phone number via Vapi -> /vapi/chat/completions) ---
# Shared secret Vapi forwards to the bridge: as "Authorization: Bearer <secret>"
# on the custom-LLM URL, and as the "x-vapi-secret" header on the server webhook.
# Leave blank to disable auth for local testing; set a strong random value before
# pointing Vapi at a publicly reachable deployment.
VAPI_SECRET=

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Scheduling ---
WORKING_DAYS=[0,1,2,3,4,5]
WORKING_HOURS_START=10
WORKING_HOURS_END=22
SLOT_MINUTES=30
BOOKING_DEFAULT_DURATION=30
BOOKING_HORIZON_DAYS=14
